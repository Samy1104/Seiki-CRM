# Supabase Edge Functions — Secrets
# À configurer via : supabase secrets set --env-file supabase/.env
# OU via le Dashboard Supabase > Settings > Edge Functions > Secrets

# Clé API Google Gemini (OBLIGATOIRE pour la génération d'emails)
# Obtenir sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy-VOTRE_CLE_ICI

# Clé API Resend (OBLIGATOIRE pour l'envoi d'emails)
# Obtenir sur : https://resend.com/api-keys
RESEND_API_KEY=re_VOTRE_CLE_ICI

# Email expéditeur Resend (doit être un domaine vérifié dans Resend)
# Vérifier votre domaine sur : https://resend.com/domains
RESEND_FROM_EMAIL=prospection@votredomaine.com
RESEND_FROM_NAME=Seiki CRM

# LinkedIn API — connexion OAuth + publication (OBLIGATOIRE pour le scheduler LinkedIn)
# Créer une app sur https://www.linkedin.com/developers/apps avec les produits
# "Sign In with LinkedIn using OpenID Connect" et "Share on LinkedIn".
# Redirect URI à enregistrer : https://<PROJECT_REF>.supabase.co/functions/v1/linkedin-oauth-callback
LINKEDIN_CLIENT_ID=votre_client_id
LINKEDIN_CLIENT_SECRET=votre_client_secret
LINKEDIN_API_VERSION=202401

# URL du front déployé, utilisée pour rediriger après connexion LinkedIn
FRONTEND_URL=https://crm.seiki.fr
